# ── Hestia core ───────────────────────────────────────────────────────────
HESTIA_PORT=8500
HESTIA_SAAS_MODE=true
HESTIA_SIGNUP_ENABLED=false
HESTIA_DATA_DIR=./data
HESTIA_PUBLIC_URL=http://127.0.0.1:8500
# Hosted SaaS domain. With Caddy wildcard DNS, studios resolve as {slug}.domain.
HESTIA_DOMAIN=
# Optional: scripts/hosted-preflight.sh probes this base URL's /healthz, /readyz,
# and /robots.txt (client-token paths must stay disallowed on the live domain).
HESTIA_PREFLIGHT_URL=
# Logs: json = one structured line per record (default); plain = human-readable dev console.
HESTIA_LOG_FORMAT=json
HESTIA_LOG_LEVEL=INFO

# ── Secrets (CHANGE in every environment; never commit real values) ─────────
# Admin master token — bearer for admin API + admin UI login gate.
HESTIA_API_TOKEN=CHANGE_ME_ADMIN
# Pepper mixed into per-studio API key hashes (hestia_tk_<slug>_<secret>).
HESTIA_TENANT_KEY_PEPPER=CHANGE_ME
# Signs UI session cookies.
HESTIA_SESSION_SECRET=CHANGE_ME

# ── AI vision provider ──────────────────────────────────────────────────────
# mock = deterministic, no API key (tests/CI/demo). xai = live xAI Grok vision.
HESTIA_VISION_BACKEND=mock
HESTIA_XAI_API_KEY=
HESTIA_XAI_BASE_URL=https://api.x.ai/v1
HESTIA_XAI_MODEL=grok-2-vision-1212

# ── Album designer ──────────────────────────────────────────────────────────
# mock = deterministic arrangement (no keys). xai = LLM proposes spread order.
HESTIA_ALBUM_BACKEND=mock

# ── Marketing content ───────────────────────────────────────────────────────
# mock = deterministic templates (no keys). xai = LLM drafts the content pack.
HESTIA_CONTENT_BACKEND=mock

# ── Product photography ─────────────────────────────────────────────────────
# mock = plan marketplace variants (no keys). xai = render via Grok Imagine.
HESTIA_PRODUCT_BACKEND=mock

# ── Storage (native gallery hosting) ────────────────────────────────────────
# local = filesystem under HESTIA_MEDIA_DIR. s3 = AWS S3 / Cloudflare R2 / MinIO.
HESTIA_STORAGE_BACKEND=local
HESTIA_MEDIA_DIR=./data/media
# s3 backend (install the `s3` extra): credentials via the standard AWS chain
# (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY).
HESTIA_S3_BUCKET=
HESTIA_S3_REGION=us-east-1
HESTIA_S3_ENDPOINT_URL=          # set for Cloudflare R2 / MinIO; blank = AWS S3
HESTIA_S3_PUBLIC_BASE_URL=       # must stay blank; public object URLs bypass gallery privacy

# ── Payments (invoice checkout) ─────────────────────────────────────────────
# mock = simulated checkout, no keys (testable). stripe = real Stripe Checkout.
HESTIA_PAYMENTS_BACKEND=mock
HESTIA_STRIPE_SECRET_KEY=
HESTIA_STRIPE_WEBHOOK_SECRET=
HESTIA_CURRENCY=usd

# ── Email (transactional notifications) ─────────────────────────────────────
# mock = record to the outbox, send nothing (testable default; see /settings/outbox).
# smtp = deliver over SMTP and still record. Leave as mock unless you mean to send.
HESTIA_EMAIL_BACKEND=mock
HESTIA_SMTP_HOST=
HESTIA_SMTP_PORT=587
HESTIA_SMTP_USER=
HESTIA_SMTP_PASSWORD=
HESTIA_SMTP_FROM=            # From: address; blank falls back to SMTP_USER

# ── Studio subscriptions (billing the studios) ──────────────────────────────
# mock = activate the chosen plan instantly, no charge (testable default).
# stripe = Checkout Session in subscription mode + webhook activation.
# Hestia has one paid plan: Hestia Studio at exactly $40/month with a 14-day trial.
HESTIA_SUBSCRIPTION_BACKEND=mock
HESTIA_TRIAL_DAYS=14

# ── Print fulfillment (paid orders → a print lab) ───────────────────────────
# mock = record the lab order and simulate acceptance (testable default).
# lab = submit to a real print lab (WHCC/Bay Photo class) over HTTP; needs BOTH the
# API key and endpoint, else paid orders record as 'failed' (the boot self-check warns).
HESTIA_FULFILLMENT_BACKEND=mock
HESTIA_FULFILLMENT_API_KEY=
HESTIA_FULFILLMENT_ENDPOINT=
