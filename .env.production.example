# Hestia — release-candidate hosted .env template.
#
# Copy to .env on the host, fill the four <SET_ME> groups, then `chmod 600 .env`.
# This is a release-candidate template, not launch approval. D1-D5 in
# docs/HUMAN-DECISIONS.md must be approved and implemented before public use.
# Self-service signup and client invoice payments deliberately remain held.
# Hosted preflight must fail both; Stripe stays in test mode until Day 7.
# The approved contracts must replace these procedural holds. Verify with:
#     bash scripts/hosted-preflight.sh                       # before boot
#     bash scripts/hosted-preflight.sh --url "https://$HESTIA_DOMAIN"   # after boot
# Full runbook: docs/launch-checklist.md · wiring: docs/deploy-wiring.md
# The full annotated knob list (incl. mock/dev values) lives in .env.example.

# ── 1. Domain (SET_ME) ──────────────────────────────────────────────────────
# Your hosted domain. Studios resolve at both {slug}.DOMAIN and DOMAIN/studio/{slug}.
# TLS is automatic (Caddy on-demand) — no DNS-provider credentials needed.
HESTIA_DOMAIN=example.com
HESTIA_PUBLIC_URL=https://example.com
HESTIA_SAAS_MODE=true
# Reverse proxies in front of the app. docker-compose sets this to 1 (Caddy) so the
# rate limiter reads the real client IP from X-Forwarded-For without trusting a spoofed
# header. Behind a CDN too (CDN → Caddy → app), set 2. Leave unset for a direct deploy.
# HESTIA_TRUSTED_PROXIES=1
# Self-service signup stays off during private rehearsal. Preflight must fail this gate.
# Set true only at the approved Day-7 opening after D1-D5 implementation evidence is
# recorded. The invite path remains an operator action, not a substitute public launch.
HESTIA_SIGNUP_ENABLED=false

# ── 2. Secrets (SET_ME — generate each with: openssl rand -hex 32) ───────────
# Never commit real values. Rotating these invalidates admin/sessions/API keys.
HESTIA_API_TOKEN=CHANGE_ME_ADMIN
HESTIA_TENANT_KEY_PEPPER=CHANGE_ME
HESTIA_SESSION_SECRET=CHANGE_ME

# ── 3. Stripe studio subscriptions (SET_ME — test keys; client invoices held) ─
# Bills studios $40/month through the platform account. Client invoice Checkout is held
# by D2; HESTIA_PAYMENTS_BACKEND=mock deliberately keeps hosted preflight red.
# Never expose the current mock invoice-payment action: it marks an invoice paid without
# charging. The release-candidate webhook scope is studio subscriptions only. Add:
#   https://example.com/webhooks/stripe
# Events: checkout.session.completed, customer.subscription.updated,
# customer.subscription.deleted. See docs/deploy-wiring.md.
HESTIA_SUBSCRIPTION_BACKEND=stripe
HESTIA_PAYMENTS_BACKEND=mock
HESTIA_STRIPE_SECRET_KEY=sk_test_CHANGE_ME
HESTIA_STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
HESTIA_CURRENCY=usd
HESTIA_TRIAL_DAYS=14

# ── 4. SMTP (SET_ME — a real sender) ────────────────────────────────────────
# Sends signup verification, client emails, and operator digests. Without it,
# verification links only hit the outbox and no one can activate. Use a domain
# sender with SPF/DKIM so mail lands. HESTIA_SMTP_FROM falls back to SMTP_USER.
HESTIA_EMAIL_BACKEND=smtp
HESTIA_SMTP_HOST=smtp.example-provider.com
HESTIA_SMTP_PORT=587
HESTIA_SMTP_USER=postmaster@example.com
HESTIA_SMTP_PASSWORD=CHANGE_ME
HESTIA_SMTP_FROM=hello@example.com

# ── Storage ─────────────────────────────────────────────────────────────────
# local = the Docker volume (default, backed up daily). For S3/R2 set
# HESTIA_STORAGE_BACKEND=s3 + HESTIA_S3_BUCKET and use a PRIVATE bucket with
# presigned URLs (public/CDN mode serves enumerable keys — see docs/deploy-wiring.md).
HESTIA_STORAGE_BACKEND=local
# HESTIA_DATA_DIR / HESTIA_MEDIA_DIR are set to /data by docker-compose — leave unset here.

# ── AI providers (controlled demos only while D1 remains held) ─────────────────
# The hosted vision allowance is usage-bound, not trial-bound, until D1 is implemented.
# Studio BYOK changes vision only; album/content xAI still use the platform key.
# Do not publish trial-AI inclusion from this release-candidate configuration.
HESTIA_VISION_BACKEND=xai
HESTIA_ALBUM_BACKEND=xai
HESTIA_CONTENT_BACKEND=xai
HESTIA_PRODUCT_BACKEND=mock
HESTIA_XAI_API_KEY=

# Current usage cap: 1 live gallery per studio, max 150 images, then mock cull.
# This is not evidence of trial eligibility.
HESTIA_AI_SUBSIDY_ENABLED=true
HESTIA_AI_SUBSIDY_GALLERIES=1
HESTIA_AI_SUBSIDY_IMAGE_CAP=150

# ── Logs / backups ──────────────────────────────────────────────────────────
HESTIA_LOG_FORMAT=json
HESTIA_LOG_LEVEL=INFO
HESTIA_BACKUP_KEEP=14
# Current preflight requires an off-site remote or durability acknowledgment with local
# storage. An rclone remote:path makes scripts/offsite-sync.sh copy DB backups and media.
# D5 additionally requires remote verification, a fresh receipt, and destination-side
# versioning, object lock, or equivalent same-path retention.
# A free-text HESTIA_MEDIA_DURABILITY_ACK can satisfy current preflight but is not launch
# evidence. S3 media is off-box, but its browser authorization parity remains held by D3.
HESTIA_OFFSITE_REMOTE=
# HESTIA_MEDIA_DURABILITY_ACK=
